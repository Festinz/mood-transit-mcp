{
  "name": "mood-transit-mcp",
  "version": "2.3.1",
  "private": true,
  "license": "MIT",
  "description": "MoodTransit(기분환승) live-catalog mood journey MCP server",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:catalog": "tsx scripts/listenbrainz-smoke.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:endpoint": "tsx scripts/endpoint-benchmark.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "24.0.13",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.3",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.7"
  }
}
